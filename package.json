{
  "name": "photostore",
  "private": true,
  "packageManager": "yarn@4.15.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace @photostore/api build",
    "print": "yarn workspace @photostore/api print",
    "deploy": "yarn workspace @photostore/api deploy",
    "deploy:sync": "yarn workspace @photostore/api deploy:sync",
    "remove": "yarn workspace @photostore/api remove",
    "remove:safe": "yarn workspace @photostore/api remove:safe",
    "env:sync": "yarn workspace @photostore/api env:sync",
    "env:backup": "yarn workspace @photostore/api env:backup",
    "typecheck": "yarn workspaces foreach -Apt run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "yarn workspace @photostore/client dev",
    "client:build": "yarn workspace @photostore/client build",
    "client:lint": "yarn workspace @photostore/client lint",
    "client:preview": "yarn workspace @photostore/client preview"
  },
  "devDependencies": {
    "prettier": "^3.5.0"
  }
}
