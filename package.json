{
  "name": "photostore-learn",
  "private": true,
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "serverless package",
    "print": "serverless print",
    "deploy": "serverless deploy",
    "deploy:sync": "serverless deploy && ./scripts/sync-client-env.sh",
    "remove": "serverless remove",
    "remove:safe": "./scripts/backup-client-env.sh && serverless remove",
    "env:sync": "./scripts/sync-client-env.sh",
    "env:backup": "./scripts/backup-client-env.sh",
    "typecheck": "tsc --noEmit",
    "client:dev": "yarn workspace photostoreclient dev",
    "client:build": "yarn workspace photostoreclient build",
    "client:lint": "yarn workspace photostoreclient lint",
    "client:preview": "yarn workspace photostoreclient preview",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.5.0",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.57.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1048.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/lib-dynamodb": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "zod": "^4.4.3"
  }
}
